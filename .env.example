# =============================================================================
# VARIÁVEIS DE AMBIENTE — BeautyHub SaaS
# Copie para .env.local e preencha os valores
# =============================================================================

# --- FRONTEND (expostas ao client via Vite - NUNCA coloque senhas aqui) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# --- BACKEND / MIGRATIONS (NUNCA usar prefixo VITE_) ---
# Connection string PostgreSQL - usada APENAS para migrations (scripts locais)
# Obtenha em: Supabase Dashboard > Settings > Database > Connection string (URI)
# Use a opção "Session pooler" (porta 6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# Opcional: para seed de usuários
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
